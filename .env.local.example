# ─────────────────────────────────────────────────────────────
#  MediOrder Pro — Environment Variables
#  Copy this file to .env.local and fill in your real values.
#  NEVER commit .env.local to git. It is in .gitignore.
# ─────────────────────────────────────────────────────────────

# Supabase project settings (Settings → API in your Supabase dashboard)
# These live ONLY on the server — they are never sent to the browser.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Used only for the browser-side Supabase auth client (cookie refresh).
# The anon key has NO privileges beyond what RLS allows.
# It is safe to expose — but we still keep it in env vars for cleanliness.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# App base URL (used for redirect URLs in auth emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
